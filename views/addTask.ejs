<!DOCTYPE html>
<html>

<head>

    <title>Add Task</title>

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

<h1>Add New Task</h1>

<form action="/tasks" method="POST">

    <input
        type="text"
        name="title"
        placeholder="Task Title"
        required
    >

    <br><br>

    <textarea
        name="description"
        placeholder="Description"
        required
    ></textarea>

    <br><br>

    <button type="submit">

        Save Task

    </button>

</form>

<br>

<a href="/tasks">

Back to Tasks

</a>

</body>

</html>