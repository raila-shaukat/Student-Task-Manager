<!DOCTYPE html>
<html>

<head>
    <title>All Tasks</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<div class="container mt-5">

    <h1>All Tasks</h1>

    <!-- Hamesha show hoga -->
    <a href="/tasks/new" class="btn btn-success mb-3">
        Add New Task
    </a>

    <% if(tasks.length === 0){ %>

        <p>No Tasks Available</p>

    <% } else { %>

        <% tasks.forEach(task => { %>

            <div class="card mb-3">

                <div class="card-body">

                    <h3><%= task.title %></h3>

                    <p><%= task.description %></p>

                    <a href="/tasks/edit/<%= task.id %>" class="btn btn-primary">
                        Edit
                    </a>

                    <form action="/tasks/delete/<%= task.id %>" method="POST" style="display:inline;">
                        <button class="btn btn-danger">
                            Delete
                        </button>
                    </form>

                </div>

            </div>

        <% }) %>

    <% } %>

</div>

</body>
</html>