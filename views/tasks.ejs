<!DOCTYPE html>
<html>

<head>
    <title>All Tasks</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<div class="container mt-5">

    <h1 class="text-center mb-4">
        All Tasks
    </h1>

    <div class="text-center mb-4">
        <a href="/tasks/new" class="btn btn-success">
            Add New Task
        </a>
    </div>

    <form action="/tasks" method="GET" class="mb-5">

        <div class="input-group">

            <input
                type="text"
                class="form-control"
                name="search"
                placeholder="Search Tasks">

            <select name="priority" class="form-select" style="max-width:200px;">

        <option value="">All Priorities</option>

        <option value="High">High</option>

        <option value="Medium">Medium</option>

        <option value="Low">Low</option>

</select>
<select name="status" class="form-select" style="max-width:200px;">

    <option value="">All Status</option>

    <option value="Pending">Pending</option>

    <option value="Completed">Completed</option>

</select>

            <button class="btn btn-primary">
                Search
            </button>

        </div>

    </form>

    <% if(tasks.length === 0){ %>

        <p>No Tasks Available</p>

    <% } else { %>

        <% tasks.forEach(task => { %>

            <div class="card mb-3">

                <div class="card-body">

                    <div class="card shadow-sm p-3 mx-auto mb-4" style="max-width:700px;">

    <div class="card-body">

        <h3 class="card-title">
            <%= task.title %>
        </h3>

        <p class="card-text">
            <%= task.description %>
        </p>

        <p>
            <strong>📅 Due Date:</strong>
            <%= task.dueDate %>
        </p>

        <p>

<strong>🚩 Priority:</strong>

<% if(task.priority === "High"){ %>

<span class="badge bg-danger">High</span>

<% } else if(task.priority === "Medium"){ %>

<span class="badge bg-warning text-dark">Medium</span>

<% } else { %>

<span class="badge bg-success">Low</span>

<% } %>

</p>

        <p>
            <strong>📌 Status:</strong>
            <%= task.status %>
        </p>

        <a href="/tasks/edit/<%= task.id %>" class="btn btn-primary btn-sm">
            Edit
        </a>

        <form action="/tasks/delete/<%= task.id %>"
              method="POST"
              style="display:inline;">

            <button class="btn btn-danger btn-sm">
                Delete
            </button>

        </form>

    </div>

</div>

                    </form>

                </div>

            </div>

        <% }) %>

    <% } %>

</div>

</body>
</html>